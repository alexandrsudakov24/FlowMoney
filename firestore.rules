rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin helper
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'alexandrsudakov24@gmail.com';
    }

    // Personal user data — only the owner or admin
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, delete: if isAdmin();

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read, delete: if isAdmin();
      }
    }

    // Family documents — any authenticated (non-anonymous) user can create;
    // members can read and update; owner can delete
    match /families/{familyId} {
      allow create: if request.auth != null && request.auth.token.email != null;
      allow read, update: if request.auth != null && request.auth.token.email != null;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.ownerId;

      // Shared expenses — readable/writable by any family member (auth enforced at app level)
      match /expenses/{expenseId} {
        allow read, write: if request.auth != null && request.auth.token.email != null;
      }

      // Family-level settings
      match /settings/{doc} {
        allow read, write: if request.auth != null && request.auth.token.email != null;
      }
    }

    // Invitations — any authenticated user can create or read their own
    match /invitations/{invitationId} {
      allow create: if request.auth != null && request.auth.token.email != null;
      allow read, update: if request.auth != null && request.auth.token.email != null;
    }
  }
}
